PORT=5000
NODE_ENV=development

# Use a random value with at least 32 characters in production.
JWT_SECRET=change_me_to_a_long_random_secret

# Comma-separated origins are supported.
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=
PUBLIC_APP_URL=http://localhost:5173

# For production on Render/Railway/VPS, point these to a persistent disk.
DATABASE_PATH=./database.db
UPLOAD_DIR=./public/uploads

# Reserved for the Supabase migration path described in the RDP.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
